# TerraWatch Configuration
# Copy this to .env and customize

APP_NAME=TerraWatch
APP_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./terrawatch.db

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Security — CHANGE THIS IN PRODUCTION!
# If not set, a random key is auto-generated at startup (not stable across restarts).
API_SECRET_KEY=change-me-to-a-random-string

# External API Keys (optional — app works without these)
FIRMS_MAP_KEY=              # NASA FIRMS (get free: firms.modaps.eosdis.nasa.gov)
OPENWEATHER_API_KEY=        # OpenWeatherMap (optional fallback)
MAPBOX_TOKEN=               # Mapbox (not used by default)

# Feature Flags
OPEN_METEO_ENABLED=True
USGS_API_ENABLED=True

# Cache
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000
CACHE_PERSIST=True          # Enable disk-backed L2 cache (SQLite)

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
